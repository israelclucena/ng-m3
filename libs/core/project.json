{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/libs/core"],
      "options": {
        "project": "libs/core/ng-package.json",
        "tsConfig": "libs/core/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/core/tsconfig.lib.prod.json",
          "project": "libs/core/ng-package.json"
        }
      }
    },
    "build-publishable": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/libs/core-publish"],
      "options": {
        "project": "libs/core/ng-package.json",
        "tsConfig": "libs/core/tsconfig.lib.json"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "storybook dev -p 4400 -c libs/core/.storybook"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/storybook/core"],
      "options": {
        "command": "storybook build -c libs/core/.storybook -o dist/storybook/core"
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS=--max-old-space-size=4096 test-storybook --config-dir libs/core/.storybook --url http://localhost:4400"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/libs/core"
      }
    }
  }
}
