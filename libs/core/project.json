{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/libs/core"],
      "options": {
        "project": "libs/core/ng-package.json",
        "tsConfig": "libs/core/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/core/tsconfig.lib.prod.json",
          "project": "libs/core/ng-package.json"
        }
      }
    },
    "build-publishable": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/libs/core-publish"],
      "options": {
        "project": "libs/core/ng-package.json",
        "tsConfig": "libs/core/tsconfig.lib.json"
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/core/.storybook",
        "browserTarget": "demo:build",
        "compodoc": false
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/core",
        "configDir": "libs/core/.storybook",
        "browserTarget": "demo:build",
        "compodoc": false
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/core/jest.config.cts",
        "tsConfig": "libs/core/tsconfig.spec.json"
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS=--max-old-space-size=4096 test-storybook --config-dir libs/core/.storybook --url http://localhost:4400"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/libs/core"
      }
    }
  }
}
