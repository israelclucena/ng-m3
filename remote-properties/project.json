{
  "name": "remote-properties",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "remote-properties/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-architects/native-federation:build",
      "options": {},
      "configurations": {
        "production": {
          "target": "remote-properties:esbuild:production"
        },
        "development": {
          "target": "remote-properties:esbuild:development",
          "dev": true
        }
      },
      "defaultConfiguration": "production"
    },
    "esbuild": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/remote-properties",
        "browser": "remote-properties/src/main.ts",
        "tsConfig": "remote-properties/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "remote-properties/public"
          }
        ],
        "styles": ["remote-properties/src/styles.css"],
        "polyfills": ["es-module-shims"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "remote-properties:esbuild:production"
        },
        "development": {
          "buildTarget": "remote-properties:esbuild:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "remote-properties/jest.config.cts",
        "tsConfig": "remote-properties/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "remote-properties:build",
        "staticFilePath": "dist/remote-properties/browser",
        "spa": true
      }
    }
  }
}
